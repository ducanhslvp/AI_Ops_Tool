APP_NAME="AIOps Platform"
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./data/aiops.db
JWT_SECRET_KEY=change-me-with-64-random-characters
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=aiops-platform
JWT_AUDIENCE=aiops-api
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
SECRET_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_MAX_CLIENTS=10000
SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_COMMAND_TIMEOUT_SECONDS=30
SSH_OUTPUT_LIMIT_BYTES=1048576
SSH_MAX_ATTEMPTS=2
SSH_KNOWN_HOSTS_FILE=~/.ssh/known_hosts
SSH_TRANSPORT=local_simulation
TEST_MODE=true
LOCAL_TEST_SNAPSHOT_PATH=tests/sample_outputs
AUTO_CREATE_SCHEMA=false
METRICS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=aiops-api
AI_PROVIDER_CONFIG_PATH=config/providers.yaml
WORKSPACE_ROOT=data/workspaces
WORKSPACE_CONTEXT_MAX_CHARS=80000
WORKSPACE_RECENT_MEMORY_FILES=5
ACTIVE_PROVIDER=mock
CODEX_MODE=cli
CODEX_EXECUTABLE=codex
CODEX_MODEL=gpt-5.6-sol
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
CLAUDE_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3
LM_STUDIO_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
