APP_ENV=production
ROWS_PER_PAGE=100
AUDIT_SSH_OUTPUT_MAX_CHARS=500
SSH_FILE_WRITE_MAX_BYTES=262144
SSH_FILE_WRITE_ALLOWED_ROOTS=/opt,/srv,/var/www,/home
SSH_FILE_READ_MAX_BYTES=262144
SSH_FILE_READ_ALLOWED_ROOTS=/opt,/srv,/var/www,/home,/var/log
DATABASE_URL=postgresql+asyncpg://aiops:replace-me@postgres:5432/aiops
JWT_SECRET_KEY=required-unique-secret-minimum-32-characters
JWT_REFRESH_SECRET_KEY=required-separate-secret-minimum-32-characters
SECRET_ENCRYPTION_KEY=required-separate-secret-minimum-32-characters
CORS_ORIGINS=https://aiops.example.com
RATE_LIMIT_PER_MINUTE=120
SSH_KNOWN_HOSTS_FILE=/app/config/known_hosts
SSH_TRANSPORT=ssh
TEST_MODE=false
AUTO_CREATE_SCHEMA=false
WORKSPACE_ROOT=/app/data/workspaces
WORKSPACE_CONTEXT_MAX_CHARS=80000
WORKSPACE_RECENT_MEMORY_FILES=5
