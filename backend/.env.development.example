APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/aiops.db
JWT_SECRET_KEY=generate-a-unique-random-value-of-at-least-32-characters
JWT_REFRESH_SECRET_KEY=generate-a-different-random-value-of-at-least-32-characters
SECRET_ENCRYPTION_KEY=generate-a-third-random-value-of-at-least-32-characters
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SSH_TRANSPORT=local_simulation
TEST_MODE=true
LOCAL_TEST_SNAPSHOT_PATH=tests/sample_outputs
AUTO_CREATE_SCHEMA=false
ROWS_PER_PAGE=100
AUDIT_SSH_OUTPUT_MAX_CHARS=500
SSH_FILE_WRITE_MAX_BYTES=262144
SSH_FILE_WRITE_ALLOWED_ROOTS=/opt,/srv,/var/www,/home
SSH_FILE_READ_MAX_BYTES=262144
SSH_FILE_READ_ALLOWED_ROOTS=/opt,/srv,/var/www,/home,/var/log
WORKSPACE_ROOT=data/workspaces
WORKSPACE_CONTEXT_MAX_CHARS=80000
WORKSPACE_RECENT_MEMORY_FILES=5
